# MiMo Code WebUI production environment example
NODE_ENV=production
MIMO_WEBUI_STRICT_RELEASE=true
HOST=127.0.0.1
PORT=8080
MIMO_HOST=127.0.0.1
MIMO_PORT=4096
# MIMO_REUSE_EXISTING=false
AUTH_TOKEN=replace-with-a-long-random-token
MIMO_CONFIG_PATH=/home/mimo-webui/.config/mimocode/config.json
MIMO_WORKSPACE_ROOT=/srv/workspaces
MIMO_SERVE_CWD=/srv/workspaces

# Optional: use only when a service account intentionally needs another MiMo home.
# MIMO_HOME=/home/mimo-webui

# Optional: use only when default XDG data/state paths are not writable.
# MIMO_DATA_HOME=/var/lib/mimo-code-webui/data
# MIMO_STATE_HOME=/var/lib/mimo-code-webui/state

# Backup policy. The systemd timer briefly stops WebUI/MiMo for a consistent
# SQLite snapshot; workspaces are intentionally excluded.
# MIMO_BACKUP_ROOT=/var/backups/mimo-code-webui
# MIMO_BACKUP_STATUS_FILE=/var/lib/mimo-code-webui/backup-status.json
# MIMO_BACKUP_MAX_AGE_MS=172800000

# Optional health monitor interval for a backend-managed mimo serve process.
# MIMO_HEALTH_INTERVAL_MS=10000
